      function calculateSimulatorValues() {
        const renda = Number($("#simIncome")?.value || 0);
        const entrada = Number($("#simDownPayment")?.value || 0);
        const prazo = Number($("#simTerm")?.value || 0);

        if (!renda || !entrada || !prazo) return null;

        const parcelaMaxima = renda * 0.3;
        const fatorFinanciamento = Math.min(0.8, prazo / 450);
        const financiamentoEstimado = fatorFinanciamento > 0 ? parcelaMaxima * prazo * 0.55 : 0;
        const imovelEstimado = financiamentoEstimado > 0 ? entrada + financiamentoEstimado : 0;
        const entradaMinima = imovelEstimado > 0 ? imovelEstimado * 0.2 : 0;

        return {
          renda,
          entrada,
          prazo,
          parcelaMaxima,
          financiamentoEstimado,
          imovelEstimado,
          entradaMinima
        };
      }

