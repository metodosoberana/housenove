      configureSocialLink("socialLinkedIn", SOCIAL_LINKEDIN);
      configureSocialLink("socialYouTube", SOCIAL_YOUTUBE);

      document.querySelectorAll("[data-target]").forEach(btn => {
        btn.addEventListener("click", () => {
          const target = btn.getAttribute("data-target");

          if ((target === "brokerCRM" || target === "capture" || target === "ownClient" || target === "agenda") && !state.brokerAuthenticated) {
            showSection("loginBroker");
            return;
          }

          if (target === "proposal") {
            if (!state.brokerAuthenticated) {
              showSection("loginBroker");
              return;
            }
            if (!state.proposalUnlocked) {
              alert("A proposta será liberada após o registro da visita.");
              return;
            }
          }

          if (target === "portfolio") renderPortfolio(portfolioItems);
          if (target === "faq") renderFAQ();
          showSection(target);
        });
      });

      $("#globalBackBtn").addEventListener("click", goBack);

      $("#openBuyerFlow").addEventListener("click", () => showSection("buyerForm"));
      $("#openSimulatorFlow").addEventListener("click", () => showSection("simulator"));

      $("#goPortfolioNow").addEventListener("click", () => {
        renderPortfolio(portfolioItems);
        showSection("portfolio");
      });

      $("#applyFilters").addEventListener("click", () => renderPortfolio(getFilteredPortfolio()));

      $("#clearFilters").addEventListener("click", () => {
        [
          "filtroBairro","filtroMetro","filtroTipo","filtroDormitorios","filtroSuites","filtroVagas",
          "filtroValor","filtroCondominio","filtroIptu","filtroLazer","filtroMetragem","filtroAndar","filtroCuradoria"
        ].forEach(id => { const el = document.getElementById(id); if (el) el.value = ""; });
        renderPortfolio(portfolioItems);
      });

      $("#sellerLeadForm").addEventListener("submit", function (e) {
        e.preventDefault();

        const payload = makePayload("seller_lead", "Proprietarios", {
          nome: $("#sellerNome").value,
          telefone: $("#sellerTelefone").value,
          bairro: $("#sellerBairro").value,
          email: $("#sellerEmail").value
        });

        console.log("SELLER_LEAD_PAYLOAD", payload);
        alert("Recebemos seus dados. A House Nove entrará em contato.");
        this.reset();
      });

      $("#buyerLeadForm").addEventListener("submit", function (e) {
        e.preventDefault();

        const payload = makePayload("buyer_personal_lead", "Compradores", {
          nome: $("#buyerNome").value,
          email: $("#buyerEmail").value,
          celular: $("#buyerCelular").value,
          jornada: $("#buyerJornada").value,
          observacoes: $("#buyerObs").value
        });

        console.log("BUYER_PERSONAL_PAYLOAD", payload);
        showSection("buyerThankYou");

        setTimeout(() => {
          renderPortfolio(portfolioItems);
          showSection("portfolio");
        }, 2200);
      });

      $("#simulatorForm").addEventListener("submit", function (e) {
        e.preventDefault();

        const values = calculateSimulatorValues();
        if (!values) {
          alert("Preencha renda, entrada e prazo para calcular a simulação.");
          return;
        }

        $("#resultInstallment").textContent = formatBRL(values.parcelaMaxima);
        $("#resultFinance").textContent = formatBRL(values.financiamentoEstimado);
        $("#resultProperty").textContent = formatBRL(values.imovelEstimado);
        $("#resultSummary").textContent =
          `Com renda de ${formatBRL(values.renda)}, a parcela mensal estimada fica em ${formatBRL(values.parcelaMaxima)}. ` +
          `Considerando ${values.prazo} meses e entrada de ${formatBRL(values.entrada)}, o valor estimado do imóvel pode chegar a ${formatBRL(values.imovelEstimado)}. ` +
          `Como referência, a entrada mínima de 20% seria ${formatBRL(values.entradaMinima)}.`;

        $("#simulatorResult").classList.remove("hidden-section");
        $("#sendSimulatorWhats").classList.remove("hidden-section");

        const payload = makePayload("purchase_power_simulation", "PoderDeCompra", {
          nome: $("#simName").value,
          telefone: $("#simPhone").value,
          email: $("#simEmail").value,
          renda: values.renda,
          entrada: values.entrada,
          prazo: values.prazo,
          parcelaEstimada: values.parcelaMaxima,
          financiamentoEstimado: values.financiamentoEstimado,
          imovelEstimado: values.imovelEstimado,
          entradaMinima: values.entradaMinima
        });

        console.log("SIMULATOR_PAYLOAD", payload);
      });

      $("#sendSimulatorWhats").addEventListener("click", () => {
        const values = calculateSimulatorValues();
        if (!values) {
          alert("Calcule a simulação antes de enviar para o Eduardo.");
          return;
        }

        const message = buildSimulatorWhatsappMessage(values);
        const url = `https://wa.me/${EDUARDO_WHATS}?text=${encodeURIComponent(message)}`;
        window.open(url, "_blank", "noopener,noreferrer");
      });

      $("#brokerLoginForm").addEventListener("submit", function (e) {
        e.preventDefault();

        const login = $("#brokerLoginEmail").value.trim();
        const password = $("#brokerLoginPassword").value.trim();
        const feedback = $("#brokerLoginFeedback");

        if (login.toUpperCase() !== DEFAULT_BROKER_LOGIN || password !== DEFAULT_BROKER_PASSWORD) {
          feedback.textContent = "Login ou senha inválidos.";
          return;
        }

        state.brokerAuthenticated = true;
        feedback.textContent = "Login realizado com sucesso.";

        const payload = makePayload("broker_login", "Corretores", {
          login,
          loggedAt: new Date().toISOString()
        });

        console.log("BROKER_LOGIN_PAYLOAD", payload);

        setTimeout(() => showSection("brokerCRM"), 300);
      });

      const qaReminder = $("#qaReminder");
      document.querySelectorAll('input[name="qaStatus"]').forEach(radio => {
        radio.addEventListener("change", () => {
          qaReminder.style.display = radio.value === "nao" && radio.checked ? "block" : "none";
        });
      });

      $("#generateDescriptionBtn").addEventListener("click", () => {
        const bairro = $("#captureDistrict").value || "bairro nobre";
        const dorms = $("#captureBedrooms").value || "x";
        const metragem = $("#captureArea").value || "x";
        const lazer = $("#captureAmenities").value || "lazer completo";

        $("#captureDescription").value =
          `Imóvel com ${metragem}m², ${dorms} dormitórios, localizado em ${bairro}. Destaque para a configuração funcional, excelente potencial de posicionamento e ${lazer}. Curadoria House Nove com foco em narrativa comercial clara, premium e orientada à conversão.`;
      });

      $("#captureForm").addEventListener("submit", function (e) {
        e.preventDefault();

        const qaSelected = document.querySelector('input[name="qaStatus"]:checked');

        const payload = makePayload("property_capture", "Imoveis", {
          domain: "imoveis",
          qaStatus: qaSelected ? qaSelected.value : "",
          cep: $("#captureCep").value,
          numero: $("#captureAddressNumber").value,
          bairro: $("#captureDistrict").value,
          proprietario: $("#captureOwner").value,
          telefoneProprietario: $("#captureOwnerPhone").value,
          tipo: $("#captureType").value,
          metragem: $("#captureArea").value,
          dormitorios: $("#captureBedrooms").value,
          suites: $("#captureSuites").value,
          vagas: $("#captureParking").value,
          valor: $("#capturePrice").value,
          condominio: $("#captureCondo").value,
          iptu: $("#captureIptu").value,
          lazer: $("#captureAmenities").value,
          midia: Array.from(document.querySelectorAll('input[name="captureMedia"]:checked')).map(el => el.value),
          descricao: $("#captureDescription").value
        });

        console.log("CAPTURE_PAYLOAD", payload);
        alert("Captação registrada com sucesso.");
        this.reset();
        qaReminder.style.display = "none";
      });

      $("#ownClientForm").addEventListener("submit", function (e) {
        e.preventDefault();

        const payload = makePayload("own_client", "ClientesProprios", {
          domain: "crm",
          corretorId: "broker_house_nove",
          nome: $("#ownClientName").value,
          email: $("#ownClientEmail").value,
          telefone: $("#ownClientPhone").value,
          origem: $("#ownClientOrigin").value,
          observacoes: $("#ownClientNotes").value
        });

        console.log("OWN_CLIENT_PAYLOAD", payload);
        alert("Cliente próprio salvo com sucesso.");
        this.reset();
      });

      $("#visitRegisterForm").addEventListener("submit", function (e) {
        e.preventDefault();

        const status = $("#visitStatus").value;
        $("#visitCurrentStatus").textContent = status || "Atualizado";

        state.proposalUnlocked = true;
        $("#unlockProposalBtn").classList.remove("opacity-50", "pointer-events-none");

        const payload = makePayload("visit_register", "Visitas", {
          domain: "agenda",
          trigger: "send_feedback_link",
          statusFinal: status,
          observacao: $("#visitObservation").value,
          impressaoComercial: $("#visitCommercialView").value,
          interesseCliente: $("#visitInterest").value,
          proximosPassos: $("#visitNextSteps").value,
          imovel: "Apartamento 43 • Vila Nova Conceição"
        });

        console.log("VISIT_REGISTER_PAYLOAD", payload);
        alert("Visita registrada com sucesso e proposta liberada.");
      });

      $("#unlockProposalBtn").addEventListener("click", () => {
        if (!state.proposalUnlocked) return;
        showSection("proposal");
      });

      $("#openProposalFromCRM").addEventListener("click", () => {
        if (!state.proposalUnlocked) {
          alert("A proposta será liberada após o registro da visita.");
          return;
        }
        showSection("proposal");
      });

      $("#proposalForm").addEventListener("submit", function (e) {
        e.preventDefault();

        const precoPedido = toNumber($("#proposalListPrice").value) / 100;
        const valorProposta = toNumber($("#proposalValue").value) / 100;
        const desconto = precoPedido > 0 ? ((precoPedido - valorProposta) / precoPedido) * 100 : 0;

        const sinal = valorProposta * 0.06;
        const segunda = valorProposta * 0.14;
        const saldo = valorProposta - sinal - segunda;

        $("#proposalFlow").innerHTML = `
          <p><strong>6% na assinatura do CCV:</strong> ${formatBRL(sinal)}</p>
          <p><strong>14% em até 30 dias:</strong> ${formatBRL(segunda)}</p>
          <p><strong>Saldo da esteira:</strong> ${formatBRL(saldo)}</p>
        `;

        $("#proposalDiscount").textContent = `${desconto.toFixed(2)}%`;

        if (desconto > 10) {
          $("#proposalStatus").textContent = "Aguardando Aprovação do Gestor";
          $("#proposalApprovalText").textContent = "Desconto acima de 10%. Minuta bloqueada até aprovação.";
          $("#btnGenerateCCV").classList.add("opacity-50", "pointer-events-none");
          $("#btnManagerApproval").classList.remove("hidden");
        } else {
          $("#proposalStatus").textContent = "Proposta apta para gerar Minuta CCV";
          $("#proposalApprovalText").textContent = "Desconto dentro da alçada comercial.";
          $("#btnGenerateCCV").classList.remove("opacity-50", "pointer-events-none");
          $("#btnManagerApproval").classList.add("hidden");
        }

        const payload = makePayload("proposal_submit", "Propostas", {
          domain: "propostas",
          imovelId: $("#proposalPropertyId").value,
          imovelTitulo: $("#proposalPropertyTitle").value,
          imovelUrl: $("#proposalPropertyUrl").value,
          precoPedido,
          valorProposta,
          desconto,
          clienteNome: $("#proposalClientName").value,
          clienteTelefone: $("#proposalClientPhone").value,
          clienteEmail: $("#proposalClientEmail").value,
          observacoes: $("#proposalNotes").value,
          pagamento: {
            recursosProprios: $("#paymentOwn").checked,
            financiamento: $("#paymentFinance").checked,
            fgts: $("#paymentFgts").checked,
            cartaConsorcio: $("#paymentConsortium").checked
          }
        });

        console.log("PROPOSAL_PAYLOAD", payload);
      });

      $("#btnGenerateCCV").addEventListener("click", function () {
        if (this.classList.contains("pointer-events-none")) return;

        const payload = makePayload("generate_ccv_minute", "CCV", {
          domain: "propostas",
          generatedAt: new Date().toISOString()
        });

        console.log("CCV_PAYLOAD", payload);
        alert("Minuta CCV liberada para geração.");
      });

      $("#btnManagerApproval").addEventListener("click", function () {
        const payload = makePayload("proposal_manager_approval_requested", "Propostas", {
          status: "Aguardando Aprovação do Gestor",
          requestedAt: new Date().toISOString()
        });

        console.log("MANAGER_APPROVAL_PAYLOAD", payload);
        alert("Solicitação de aprovação enviada ao gestor.");
      });

      $("#recruitmentForm").addEventListener("submit", function (e) {
        e.preventDefault();

        const payload = makePayload("recruitment_apply", "Candidaturas", {
          domain: "rh",
          nome: $("#recruitName").value,
          email: $("#recruitEmail").value,
          celular: $("#recruitPhone").value,
          escolaridade: $("#recruitEducation").value,
          curso: $("#recruitCourse").value,
          vaga: $("#recruitRole").value,
          diferencial: $("#recruitDifferential").value
        });

        console.log("RECRUITMENT_PAYLOAD", payload);
        alert("Candidatura enviada com sucesso.");
        this.reset();
      });

      renderPortfolio(portfolioItems);
      renderFAQ();
      showSection("home", false);
    })();
  </script>
</body>
</html>
