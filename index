<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>House Nove | Personal Shopper Imobiliário</title>
  <meta
    name="description"
    content="House Nove: experiência imobiliária com curadoria, segurança, atendimento humano e jornada assistida."
  />

  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css"
  />
  <link
    href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700;900&family=Inter:wght@300;400;600;700&display=swap"
    rel="stylesheet"
  />

  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            hnPurple: "#572580",
            hnOrange: "#ff9600",
            hnDark: "#1a0d24",
          },
          fontFamily: {
            premium: ["Montserrat", "sans-serif"],
            body: ["Inter", "sans-serif"],
          },
        },
      },
    };
  </script>

  <style>
    :root {
      --h9-purple: #572580;
      --h9-orange: #ff9600;
      --h9-dark: #1a0d24;
      --glass-bg: rgba(255, 255, 255, 0.03);
      --glass-border: rgba(255, 255, 255, 0.1);
      --input-bg: rgba(0, 0, 0, 0.2);
      --input-bg-focus: rgba(0, 0, 0, 0.35);
      --soft-text: rgba(255, 255, 255, 0.78);
      --muted-text: rgba(255, 255, 255, 0.55);
      --orange-shadow: 0 8px 25px rgba(255, 150, 0, 0.18);
      --shadow: 0 18px 55px rgba(0, 0, 0, 0.28);
      --radius-xl: 26px;
      --radius-lg: 18px;
      --radius-md: 12px;
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }

    body {
      margin: 0;
      font-family: "Inter", sans-serif;
      color: #fff;
      background-color: var(--h9-purple);
      background-image:
        linear-gradient(rgba(87, 37, 128, 0.72), rgba(87, 37, 128, 0.72)),
        url("POST-HOUSE-P-BANNER.png");
      background-size: cover;
      background-position: center;
      background-attachment: fixed;
      min-height: 100vh;
    }

    @media (max-width: 768px) {
      body { background-attachment: scroll; }
    }

    .hidden-section { display: none !important; }

    .glass-card {
      background: var(--glass-bg);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow);
    }

    .section-tag {
      display: inline-block;
      padding: 8px 14px;
      border-radius: 999px;
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.08);
      color: rgba(255,255,255,0.82);
      font-size: 11px;
      font-weight: 900;
      letter-spacing: 1px;
      text-transform: uppercase;
      margin-bottom: 16px;
    }

    .input-h9,
    .select-h9,
    .textarea-h9 {
      width: 100%;
      padding: 16px;
      border-radius: 16px;
      border: 1px solid rgba(255,255,255,0.12);
      background: var(--input-bg);
      color: #fff;
      outline: none;
      transition: 0.25s ease;
      appearance: none;
    }

    .input-h9::placeholder,
    .textarea-h9::placeholder {
      color: rgba(255,255,255,0.48);
    }

    .input-h9:focus,
    .select-h9:focus,
    .textarea-h9:focus {
      border-color: var(--h9-orange);
      background: var(--input-bg-focus);
      box-shadow: 0 0 0 4px rgba(255,150,0,0.12);
    }

    .textarea-h9 {
      min-height: 120px;
      resize: vertical;
    }

    .btn-h9 {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      width: 100%;
      padding: 16px 22px;
      border-radius: 18px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      transition: 0.25s ease;
      cursor: pointer;
      text-decoration: none;
      border: 1px solid transparent;
    }

    .btn-primary {
      background: var(--h9-orange);
      color: #1a0d24;
      box-shadow: var(--orange-shadow);
    }

    .btn-primary:hover {
      transform: translateY(-2px);
      filter: brightness(1.04);
    }

    .btn-outline {
      background: transparent;
      border-color: var(--h9-orange);
      color: var(--h9-orange);
    }

    .btn-outline:hover {
      background: rgba(255,150,0,0.06);
      transform: translateY(-2px);
    }

    .btn-ghost {
      background: rgba(255,255,255,0.04);
      border-color: rgba(255,255,255,0.1);
      color: rgba(255,255,255,0.86);
    }

    .btn-ghost:hover {
      background: rgba(255,255,255,0.08);
      transform: translateY(-2px);
    }

    .page-shell {
      width: 100%;
      max-width: 1380px;
      padding: 0 24px 96px;
    }

    .top-left-back {
      position: fixed;
      top: 20px;
      left: 20px;
      z-index: 60;
      display: none;
    }

    .top-right-actions {
      position: fixed;
      top: 20px;
      right: 20px;
      z-index: 60;
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .pill-btn {
      padding: 11px 18px;
      border-radius: 999px;
      border: 1px solid rgba(255,255,255,0.12);
      background: rgba(255,255,255,0.06);
      color: #fff;
      font-weight: 800;
      text-transform: uppercase;
      font-size: 11px;
      letter-spacing: 0.06em;
      transition: 0.25s ease;
      cursor: pointer;
    }

    .pill-btn:hover {
      transform: translateY(-2px);
      color: var(--h9-orange);
    }

    .pill-btn.orange {
      background: var(--h9-orange);
      color: #1a0d24;
      border-color: transparent;
    }

    .pill-btn.orange:hover {
      color: #1a0d24;
      filter: brightness(1.04);
    }

    .floating-whatsapp {
      position: fixed;
      right: 30px;
      bottom: 30px;
      width: 76px;
      height: 76px;
      border-radius: 50%;
      border: 3px solid var(--h9-orange);
      background-image: url("Gabi-removebg-preview.png");
      background-color: var(--h9-purple);
      background-size: 110%;
      background-position: top center;
      background-repeat: no-repeat;
      box-shadow: 0 4px 20px rgba(0,0,0,0.42);
      z-index: 80;
      transition: transform 0.25s ease;
    }

    .floating-whatsapp:hover {
      transform: scale(1.06);
    }

    .floating-whatsapp-badge {
      position: absolute;
      right: 0;
      bottom: 0;
      width: 24px;
      height: 24px;
      border: 2px solid #fff;
      border-radius: 50%;
      background: #25d366;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 12px;
    }

    .portfolio-layout {
      display: grid;
      grid-template-columns: 320px 1fr;
      gap: 28px;
      align-items: start;
    }

    .sticky-panel {
      position: sticky;
      top: 92px;
    }

    .filter-pills {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .filter-pill {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 9px 14px;
      border-radius: 999px;
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.08);
      font-size: 12px;
      font-weight: 800;
      color: rgba(255,255,255,0.82);
      text-transform: uppercase;
      letter-spacing: .04em;
    }

    .portfolio-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 24px;
    }

    .property-card-image {
      height: 210px;
      background:
        linear-gradient(135deg, rgba(255,255,255,0.05), rgba(255,150,0,0.08)),
        rgba(0,0,0,0.14);
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }

    .property-pill {
      display: inline-flex;
      align-items: center;
      padding: 7px 11px;
      border-radius: 999px;
      border: 1px solid rgba(255,255,255,0.08);
      background: rgba(255,255,255,0.04);
      font-size: 11px;
      font-weight: 800;
      color: rgba(255,255,255,0.84);
      text-transform: uppercase;
    }

    .map-card {
      position: relative;
      overflow: hidden;
      min-height: 420px;
      background:
        radial-gradient(circle at 50% 40%, rgba(255,150,0,0.12), transparent 18%),
        linear-gradient(180deg, rgba(0,0,0,0.08), rgba(0,0,0,0.18));
    }

    .map-svg {
      width: 100%;
      height: 100%;
      min-height: 420px;
      display: block;
    }

    .faq-item {
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 18px;
      background: rgba(255,255,255,0.02);
      overflow: hidden;
      margin-bottom: 16px;
    }

    .faq-question {
      width: 100%;
      background: transparent;
      border: none;
      color: #fff;
      padding: 20px 22px;
      text-align: left;
      font-weight: 800;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      cursor: pointer;
    }

    .faq-answer {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease;
      color: rgba(255,255,255,0.76);
      font-size: 14px;
      line-height: 1.8;
    }

    .faq-answer-inner {
      padding: 0 22px 22px;
    }

    .footer-grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr 1fr;
      gap: 32px;
      align-items: start;
    }

    .footer-title {
      font-family: "Montserrat", sans-serif;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      margin-bottom: 16px;
      color: #fff;
      font-size: 12px;
    }

    .footer-link {
      background: transparent;
      border: none;
      padding: 0;
      text-align: left;
      color: rgba(255,255,255,0.74);
      font-size: 14px;
      cursor: pointer;
      text-decoration: none;
      transition: color 0.25s ease;
    }

    .footer-link:hover {
      color: var(--h9-orange);
    }

    .footer-legal {
      color: rgba(255,255,255,0.52);
      font-size: 11px;
      line-height: 1.7;
    }

    .trust-footer-row {
      display: flex;
      flex-wrap: wrap;
      gap: 18px;
      justify-content: space-between;
      align-items: center;
    }

    .social-bar {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      align-items: center;
    }

    .social-link {
      width: 42px;
      height: 42px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 999px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08);
      color: rgba(255,255,255,0.82);
      text-decoration: none;
      transition: 0.25s ease;
    }

    .social-link:hover {
      color: var(--h9-orange);
      transform: translateY(-2px);
      background: rgba(255,255,255,0.08);
    }

    .trust-bar {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      justify-content: flex-end;
      align-items: center;
    }

    .trust-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.07);
      font-size: 10px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: rgba(255,255,255,0.72);
    }

    .notice-box {
      padding: 14px 16px;
      border-radius: 16px;
      background: rgba(255,150,0,0.08);
      border: 1px dashed rgba(255,150,0,0.32);
      color: rgba(255,255,255,0.86);
      font-size: 13px;
      display: none;
    }

    @media (max-width: 1024px) {
      .portfolio-layout,
      .footer-grid,
      .portfolio-grid {
        grid-template-columns: 1fr;
      }

      .trust-footer-row,
      .trust-bar,
      .social-bar {
        justify-content: center;
      }

      .top-right-actions {
        left: 12px;
        right: 12px;
        justify-content: center;
      }

      .top-left-back {
        left: 12px;
        top: 76px;
      }

      .sticky-panel {
        position: static;
      }
    }
  </style>
</head>
<body class="flex flex-col items-center">

  <button id="globalBackBtn" class="top-left-back pill-btn">
    <i class="fas fa-arrow-left"></i> Voltar
  </button>

  <div class="top-right-actions">
    <button class="pill-btn secondary" data-target="portfolio">
      <i class="fas fa-search"></i> Buscar imóveis
    </button>
    <button class="pill-btn orange" data-target="loginBroker">
      <i class="fas fa-user-tie"></i> Área do Corretor
    </button>
  </div>

  <a
    href="https://wa.me/5511976022147"
    target="_blank"
    rel="noopener noreferrer"
    class="floating-whatsapp"
    aria-label="Falar com a House Nove no WhatsApp"
  >
    <span class="floating-whatsapp-badge"><i class="fab fa-whatsapp text-white"></i></span>
  </a>

  <!-- HOME -->
  <section id="homeSection" class="w-full flex flex-col items-center">
    <header class="w-full pt-16 pb-12 flex justify-center">
      <img src="logo vertical 1.png" alt="House Nove" class="h-32 md:h-48 object-contain" />
    </header>

    <div class="w-full max-w-4xl px-6 mb-16 text-center">
      <h1 class="font-premium text-2xl md:text-4xl font-black uppercase italic leading-none">
        Tecnologia imobiliária <span class="text-hnOrange">focada</span> no atendimento de qualidade!
      </h1>
    </div>

    <main class="w-full max-w-2xl px-6 pb-12 space-y-10">
      <section class="glass-card p-8 md:p-12">
        <span class="section-tag">Proprietários</span>
        <h2 class="font-premium text-2xl md:text-3xl font-black mb-4 uppercase">Quero vender meu imóvel</h2>
        <p class="text-white/74 text-sm leading-7 mb-6">
          Preencha seus dados para a House Nove entrar em contato, analisar o potencial de captação
          e entender se o seu imóvel faz sentido para o nosso portfólio.
        </p>

        <form id="sellerLeadForm" class="space-y-4">
          <input id="sellerNome" type="text" placeholder="Nome Completo" class="input-h9" required />
          <div class="grid md:grid-cols-2 gap-4">
            <input id="sellerTelefone" type="tel" placeholder="Telefone" class="input-h9" required />
            <input id="sellerBairro" type="text" placeholder="Bairro" class="input-h9" required />
          </div>
          <input id="sellerEmail" type="email" placeholder="E-mail" class="input-h9" required />
          <button type="submit" class="btn-h9 btn-primary">Quero vender</button>
        </form>
      </section>

      <section class="glass-card p-8 md:p-12">
        <span class="section-tag">Novo!</span>
        <h2 class="font-premium text-2xl md:text-3xl font-black mb-4 uppercase">Jornada com PS</h2>
        <p class="text-white/74 text-sm leading-7 mb-8">
          Acesso a um portfólio exclusivo e jornada assistida nas maiores proptechs, com o filtro humano,
          estratégico e curado da House Nove.
        </p>
        <button type="button" id="openBuyerFlow" class="btn-h9 btn-outline">Quero comprar</button>
      </section>

      <section class="glass-card p-8 md:p-12">
        <span class="section-tag">Poder de Compra</span>
        <h2 class="font-premium text-2xl md:text-3xl font-black mb-4 uppercase">Descubra quanto pode ser sua casa</h2>
        <p class="text-white/74 text-sm leading-7 mb-8">
          Faça aqui sua simulação de financiamento, entenda seu poder de compra com uma estimativa inicial
          e siga para o próximo passo com apoio humano.
        </p>
        <button type="button" id="openSimulatorFlow" class="btn-h9 btn-outline">Simular financiamento</button>
      </section>
    </main>

    <section class="w-full flex justify-center px-6 pb-16">
      <div class="w-64 h-64 rounded-2xl overflow-hidden border border-white/10 shadow-2xl">
        <video autoplay loop muted playsinline class="w-full h-full object-cover">
          <source src="Animação com fundo .mp4" type="video/mp4" />
        </video>
      </div>
    </section>
  </section>

  <!-- BUYER FORM -->
  <section id="buyerFormSection" class="hidden-section w-full px-6 py-12">
    <div class="max-w-3xl mx-auto glass-card p-8 md:p-10">
      <span class="section-tag">Personal Shopper</span>
      <h2 class="font-premium text-3xl md:text-4xl font-black uppercase mb-6">Jornada com PS</h2>

      <form id="buyerLeadForm" class="space-y-4">
        <input id="buyerNome" type="text" placeholder="Seu Nome" class="input-h9" required />
        <input id="buyerEmail" type="email" placeholder="Seu E-mail" class="input-h9" required />
        <input id="buyerCelular" type="tel" placeholder="Seu Celular" class="input-h9" required />
        <select id="buyerJornada" class="select-h9" required>
          <option value="">Sua fase atual</option>
          <option value="inicio">Iniciando agora</option>
          <option value="pesquisa">Já pesquisando</option>
          <option value="visitas">Já visitando imóveis</option>
          <option value="proposta">Pronto para propor</option>
        </select>
        <textarea id="buyerObs" class="textarea-h9" placeholder="Conte um pouco do que você procura"></textarea>
        <button type="submit" class="btn-h9 btn-primary">Enviar</button>
      </form>
    </div>
  </section>

  <!-- BUYER THANKS -->
  <section id="buyerThankYouSection" class="hidden-section w-full px-6 py-12">
    <div class="max-w-3xl mx-auto glass-card p-8 md:p-12 text-center space-y-6">
      <span class="section-tag">Recebido</span>
      <h2 class="font-premium text-3xl md:text-4xl font-black uppercase">Obrigado pelo envio</h2>
      <p class="text-white/75 leading-7">
        Sua jornada com Personal Shopper foi registrada com sucesso. Agora vamos te direcionar
        para a busca inicial de imóveis para você começar a explorar opções alinhadas ao seu momento.
      </p>
      <button id="goPortfolioNow" type="button" class="btn-h9 btn-primary max-w-sm mx-auto">
        Ir para busca de imóveis
      </button>
    </div>
  </section>

  <!-- PODER DE COMPRA -->
  <section id="simulatorSection" class="hidden-section w-full px-6 py-12">
    <div class="max-w-4xl mx-auto glass-card p-8 md:p-10 space-y-8">
      <div class="text-center space-y-3">
        <span class="section-tag">Poder de Compra</span>
        <h2 class="font-premium text-3xl md:text-5xl font-black uppercase">Simulação de financiamento</h2>
        <p class="text-white/75 max-w-3xl mx-auto leading-7">
          Descubra quanto pode ser sua casa com uma estimativa inicial baseada em renda, entrada e prazo.
          Esse cálculo é uma referência de viabilidade, não uma promessa de crédito.
        </p>
      </div>

      <form id="simulatorForm" class="space-y-6">
        <div class="grid md:grid-cols-2 gap-4">
          <input id="simName" type="text" class="input-h9" placeholder="Nome completo" required />
          <input id="simPhone" type="tel" class="input-h9" placeholder="WhatsApp" required />
        </div>

        <div class="grid md:grid-cols-2 gap-4">
          <input id="simEmail" type="email" class="input-h9" placeholder="E-mail" required />
          <input id="simIncome" type="number" min="0" step="0.01" class="input-h9" placeholder="Renda mensal" required />
        </div>

        <div class="grid md:grid-cols-2 gap-4">
          <input id="simDownPayment" type="number" min="0" step="0.01" class="input-h9" placeholder="Valor de entrada" required />
          <select id="simTerm" class="select-h9" required>
            <option value="">Prazo desejado</option>
            <option value="120">120 meses</option>
            <option value="180">180 meses</option>
            <option value="240">240 meses</option>
            <option value="300">300 meses</option>
            <option value="360">360 meses</option>
          </select>
        </div>

        <div id="simulatorResult" class="glass-card p-6 space-y-4 hidden-section">
          <div>
            <h3 class="font-premium text-2xl font-black uppercase">Resultado da simulação</h3>
            <p class="text-white/70 text-sm mt-2">
              Estimativa inicial para orientar sua jornada de compra e a conversa com o correspondente.
            </p>
          </div>

          <div class="grid md:grid-cols-3 gap-4">
            <div class="bg-white/5 border border-white/10 rounded-2xl p-4">
              <p class="text-white/60 text-xs uppercase tracking-widest">Parcela estimada</p>
              <p id="resultInstallment" class="text-hnOrange font-black text-xl mt-2">R$ 0,00</p>
            </div>
            <div class="bg-white/5 border border-white/10 rounded-2xl p-4">
              <p class="text-white/60 text-xs uppercase tracking-widest">Financiamento estimado</p>
              <p id="resultFinance" class="text-hnOrange font-black text-xl mt-2">R$ 0,00</p>
            </div>
            <div class="bg-white/5 border border-white/10 rounded-2xl p-4">
              <p class="text-white/60 text-xs uppercase tracking-widest">Imóvel estimado</p>
              <p id="resultProperty" class="text-hnOrange font-black text-xl mt-2">R$ 0,00</p>
            </div>
          </div>

          <div class="bg-white/5 border border-white/10 rounded-2xl p-4">
            <p id="resultSummary" class="text-white/75 leading-7 text-sm"></p>
          </div>
        </div>

        <div class="flex flex-wrap gap-4">
          <button type="submit" class="btn-h9 btn-primary md:max-w-xs">Calcular simulação</button>
          <button type="button" id="sendSimulatorWhats" class="btn-h9 btn-outline md:max-w-sm hidden-section">Falar com Eduardo</button>
        </div>
      </form>
